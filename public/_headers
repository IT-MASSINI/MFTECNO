# ═══════════════════════════════════════════════════════════════════════════
#  MF TECNO - Cloudflare Pages Headers - OTTIMIZZATO SEO + SECURITY A
#  ---------------------------------------------------------------------------
#  OBIETTIVI (in ordine di priorità):
#  1. SEO: massimizzare crawl budget, Rich Snippets, Core Web Vitals
#  2. Google Analytics 4 / Tag Manager: compatibilità 100%
#  3. Security: grade A su SecurityHeaders.com e Mozilla Observatory
#
#  FILOSOFIA:
#  • _headers è l'UNICA fonte di verità (nuxt-security rimosso)
#  • CSP permissiva su style (compatibilità Bootstrap/Swiper) ma stretta su script
#  • Cache aggressiva su asset, cache edge con revalidate su HTML (crawl budget ↑)
#  • X-Robots-Tag esplicito per controllare l'indicizzazione di ogni tipo di file
#
#  POSIZIONE FILE: public/_headers  (nessuna estensione, due spazi di indent)
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
#  REGOLA GLOBALE - tutte le rotte (HTML, API, 404, ecc.)
# ═══════════════════════════════════════════════════════════════════════════
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://static.cloudflareinsights.com https://www.google.com https://www.gstatic.com; script-src-attr 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://*.analytics.google.com https://*.google-analytics.com https://*.googletagmanager.com https://stats.g.doubleclick.net https://cloudflareinsights.com https://static.cloudflareinsights.com https://www.google.com; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://www.google.com https://td.doubleclick.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; manifest-src 'self'; worker-src 'self' blob:; media-src 'self' https:; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), autoplay=(self), camera=(), cross-origin-isolated=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), keyboard-map=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(self), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(self), usb=(), web-share=(self), xr-spatial-tracking=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Permitted-Cross-Domain-Policies: none
  Origin-Agent-Cluster: ?1
  X-XSS-Protection: 0
  X-Download-Options: noopen
  X-DNS-Prefetch-Control: on


# ═══════════════════════════════════════════════════════════════════════════
#  HTML PAGES - Cache ottimizzata per crawl budget Googlebot
#  ---------------------------------------------------------------------------
#  Strategia: browser non cacha (max-age=0), ma l'edge Cloudflare sì (s-maxage).
#  Googlebot riceve la risposta dall'edge in <50ms → migliora crawl rate.
#  stale-while-revalidate: serve la versione stale mentre rivalida in background
#  → nessun visitatore mai aspetta.
#  X-Robots-Tag esplicito: ridondante con <meta robots> ma segnale più forte.
# ═══════════════════════════════════════════════════════════════════════════
/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1

/*.html
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1


# ═══════════════════════════════════════════════════════════════════════════
#  ASSET NUXT BUILD - cache immutabile + preload via header per LCP
#  ---------------------------------------------------------------------------
#  I file sotto /_nuxt/ hanno hash nel nome (es. entry.abc123.js)
#  quindi cache 1 anno immutabile è sicura al 100%.
#  X-Robots-Tag: noindex  evita che Google indicizzi file .js/.css come pagine.
# ═══════════════════════════════════════════════════════════════════════════
/_nuxt/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
  X-Robots-Tag: noindex


# ═══════════════════════════════════════════════════════════════════════════
#  IMMAGINI STATICHE - indicizzate da Google Image Search
#  ---------------------------------------------------------------------------
#  X-Robots-Tag: index, follow  è CRUCIALE per Google Images.
#  max-image-preview:large  permette anteprime grandi in SERP (+CTR).
# ═══════════════════════════════════════════════════════════════════════════
/images/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: same-origin
  X-Robots-Tag: index, follow, max-image-preview:large

/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: index, follow, max-image-preview:large

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: index, follow, max-image-preview:large

/*.png
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: index, follow, max-image-preview:large

/*.webp
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: index, follow, max-image-preview:large

/*.avif
  Cache-Control: public, max-age=31536000, immutable
  X-Robots-Tag: index, follow, max-image-preview:large

/*.svg
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/svg+xml
  X-Robots-Tag: index, follow


# ═══════════════════════════════════════════════════════════════════════════
#  FONT LOCALI - CORS + cache aggressiva
#  ---------------------------------------------------------------------------
#  X-Robots-Tag: noindex  evita che Google tratti i .woff2 come risorse indicizzabili.
# ═══════════════════════════════════════════════════════════════════════════
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  X-Robots-Tag: noindex

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  X-Robots-Tag: noindex

/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
  Cross-Origin-Resource-Policy: cross-origin
  X-Robots-Tag: noindex


# ═══════════════════════════════════════════════════════════════════════════
#  JAVASCRIPT e CSS (public root)
# ═══════════════════════════════════════════════════════════════════════════
/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8
  X-Robots-Tag: noindex

/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8
  X-Robots-Tag: noindex

/*.mjs
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8
  X-Robots-Tag: noindex


# ═══════════════════════════════════════════════════════════════════════════
#  FILE SEO CRITICI - sitemap e robots
#  ---------------------------------------------------------------------------
#  sitemap.xml: cache 1 ora (Google ricontrolla spesso dopo modifiche)
#  robots.txt:  cache 24 ore
#  Entrambi DEVONO essere indicizzabili (no X-Robots-Tag: noindex!).
# ═══════════════════════════════════════════════════════════════════════════
/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
  Content-Type: application/xml; charset=utf-8

/sitemap*.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8


# ═══════════════════════════════════════════════════════════════════════════
#  PWA MANIFEST + FAVICON
# ═══════════════════════════════════════════════════════════════════════════
/*.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=86400
  X-Robots-Tag: noindex

/site.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=86400

/favicon.ico
  Cache-Control: public, max-age=604800
  Content-Type: image/x-icon
  X-Robots-Tag: noindex

/favicon.svg
  Cache-Control: public, max-age=604800
  Content-Type: image/svg+xml
  X-Robots-Tag: noindex

/apple-touch-icon.png
  Cache-Control: public, max-age=604800
  Content-Type: image/png
  X-Robots-Tag: noindex


# ═══════════════════════════════════════════════════════════════════════════
#  API ENDPOINTS - non cacheate, non indicizzate
#  ---------------------------------------------------------------------------
#  CRITICO: se un'API finisce in Google, rovina il sitelink e confonde gli utenti.
# ═══════════════════════════════════════════════════════════════════════════
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff


# ═══════════════════════════════════════════════════════════════════════════
#  PREVIEW CLOUDFLARE (mftecno.pages.dev) - NON INDICIZZARE
#  ---------------------------------------------------------------------------
#  IMPORTANTE: il dominio .pages.dev è solo di preview. Se Google lo indicizza
#  crei duplicate content con www.mftecno.com (penalizzazione SEO).
#  Questa regola è catch-all per path hash-based di preview.
#  Rimuovila quando sarai solo su www.mftecno.com.
# ═══════════════════════════════════════════════════════════════════════════

