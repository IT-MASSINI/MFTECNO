{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/data/*": ["./data/*"],
      "~/data/*": ["./data/*"],
      "@/types/*": ["./types/*"],
      "~/types/*": ["./types/*"],
      "@/pinia/*": ["./pinia/*"],
      "~/pinia/*": ["./pinia/*"]
    },
    "moduleResolution": "node"
  }
}
