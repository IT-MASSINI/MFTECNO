{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",   // ← aggiunto
    "moduleResolution": "bundler", // ← era "node"
    "paths": {
      "@/data/*": ["./data/*"],
      "~/data/*": ["./data/*"],
      "@/types/*": ["./types/*"],
      "~/types/*": ["./types/*"],
      "@/pinia/*": ["./pinia/*"],
      "~/pinia/*": ["./pinia/*"]
    }
  }
}